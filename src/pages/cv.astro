---
import Academic from '../layouts/Academic.astro';
---
<Academic title="CV">
  <div class="cv-header">
    <h1 class="page-title">Curriculum Vitae</h1>
    <a href="/cv.pdf" class="download">Download PDF ↓</a>
  </div>

  <section class="cv-section">
    <h2 class="section-label">Education</h2>
    <div class="cv-entries">
      <div class="cv-entry">
        <div class="cv-entry-meta">
          <span class="cv-date">2026 – present</span>
        </div>
        <div class="cv-entry-body">
          <p class="cv-role">PhD in Computer Science</p>
          <p class="cv-org">University Name</p>
          <p class="cv-detail">Advisor: Professor Name</p>
        </div>
      </div>
      <div class="cv-entry">
        <div class="cv-entry-meta">
          <span class="cv-date">2022 – 2026</span>
        </div>
        <div class="cv-entry-body">
          <p class="cv-role">BSc in Computer Science</p>
          <p class="cv-org">University Name</p>
          <p class="cv-detail">Graduated with honours</p>
        </div>
      </div>
    </div>
  </section>

  <section class="cv-section">
    <h2 class="section-label">Research Interests</h2>
    <p class="cv-prose">
      A brief statement of your research interests. What problems do you work on?
      What methods or areas do you draw from?
    </p>
  </section>

  <section class="cv-section">
    <h2 class="section-label">Publications</h2>
    <div class="cv-entries">
      <div class="cv-entry">
        <div class="cv-entry-meta">
          <span class="cv-date">2026</span>
        </div>
        <div class="cv-entry-body">
          <p class="cv-role">Title of Your Paper</p>
          <p class="cv-org">Conference / Journal Name</p>
          <p class="cv-detail">Your Name, Co-author One, Co-author Two</p>
        </div>
      </div>
    </div>
  </section>

  <section class="cv-section">
    <h2 class="section-label">Awards &amp; Honours</h2>
    <div class="cv-entries">
      <div class="cv-entry">
        <div class="cv-entry-meta">
          <span class="cv-date">2026</span>
        </div>
        <div class="cv-entry-body">
          <p class="cv-role">Award Name</p>
          <p class="cv-org">Awarding Body</p>
        </div>
      </div>
    </div>
  </section>

  <section class="cv-section">
    <h2 class="section-label">Teaching</h2>
    <div class="cv-entries">
      <div class="cv-entry">
        <div class="cv-entry-meta">
          <span class="cv-date">2026</span>
        </div>
        <div class="cv-entry-body">
          <p class="cv-role">Teaching Assistant — Course Name</p>
          <p class="cv-org">University Name</p>
        </div>
      </div>
    </div>
  </section>
</Academic>

<style>
  .cv-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 3rem;
  }

  .page-title {
    font-size: 1.6rem;
    font-weight: 400;
    color: var(--fg);
    letter-spacing: -0.01em;
  }

  .download {
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    border-bottom: 1px solid rgba(94, 129, 172, 0.25);
    padding-bottom: 1px;
    transition: color 0.2s, border-color 0.2s;
  }

  .download:hover {
    color: var(--fg);
    border-color: var(--fg);
  }

  .cv-section {
    margin-bottom: 2.8rem;
  }

  .section-label {
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 1.2rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(94, 129, 172, 0.10);
  }

  .cv-entries {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .cv-entry {
    display: grid;
    grid-template-columns: 6.5rem 1fr;
    gap: 1rem;
    align-items: baseline;
  }

  .cv-date {
    font-size: 0.76rem;
    color: var(--muted);
    white-space: nowrap;
    letter-spacing: 0.02em;
  }

  .cv-role {
    font-size: 0.90rem;
    font-weight: 500;
    color: var(--fg);
    margin-bottom: 0.15rem;
  }

  .cv-org {
    font-size: 0.82rem;
    color: var(--accent2);
    margin-bottom: 0.1rem;
  }

  .cv-detail {
    font-size: 0.78rem;
    color: var(--muted);
    font-weight: 300;
  }

  .cv-prose {
    font-size: 0.88rem;
    line-height: 1.75;
    color: #D8DEE9;
    font-weight: 300;
    max-width: 560px;
  }
</style>
